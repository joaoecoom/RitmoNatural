# Copia para secrets/local.env e preenche. Este ficheiro é seguro commitar; local.env não.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Obrigatório para `npm run db:apply` (password da base em Settings → Database)
SUPABASE_DB_PASSWORD=

# Opcional: URI Postgres completo (substitui a montagem a partir da password)
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

OPENROUTER_API_KEY=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
