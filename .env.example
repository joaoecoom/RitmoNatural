NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Password da base Postgres (Dashboard → Settings → Database). Necessária para `npm run db:apply`.
# Podes concentrar segredos em secrets/local.env — ver secrets/README.md
SUPABASE_DB_PASSWORD=
# Alternativa: URI completo em vez de SUPABASE_DB_PASSWORD
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# LLM (OpenRouter) — texto da Voz e interpretação de refeições
OPENROUTER_API_KEY=

# TTS (OpenAI) — gera MP3 para mensagens da Voz após check-in / refeição / onboarding
OPENAI_API_KEY=

# URL pública da app (redirects Stripe, links nos pushes)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — checkout one-time e webhook
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Opcional: mapear slugs de programas para Price IDs (sobrepõe a coluna programs.stripe_price_id)
# STRIPE_PROGRAM_PRICE_IDS={"protocolo-7-dias":"price_xxx","sistema-completo-regulacao":"price_yyy"}

# Web Push — gera chaves com: npx web-push generate-vapid-keys
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:contacto@teudominio.pt

# Protege /api/cron/daily-reminders (Authorization: Bearer … ou ?secret=)
CRON_SECRET=

# Bootstrap super admin (script npm run bootstrap:admin)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
